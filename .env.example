# ──────────────────────────────────────────────────────────────
#  Starter AI Agents — Shared Environment Variables
#  Copy this file to .env in any agent folder and fill in keys.
# ──────────────────────────────────────────────────────────────

# Required by most agents
OPENAI_API_KEY=sk-...

# Optional: xAI Grok (xai_finance_agent)
XAI_API_KEY=xai-...

# Optional: Replicate (ai_music_generator_agent)
REPLICATE_API_TOKEN=r8_...

# Optional: Tavily web search (ai_startup_trend_analysis_agent)
TAVILY_API_KEY=tvly-...
